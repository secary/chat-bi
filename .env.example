LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key
# Optional, only needed for OpenAI-compatible proxy or non-default endpoint.
API_BASE=
# For OpenAI-compatible vendors (e.g. Volcengine ARK), use:
# LLM_MODEL=openai/deepseek-v3-2-251201
# API_BASE=https://ark.cn-beijing.volces.com/api/v3
# MiniMax OpenAI-compatible example:
# LLM_MODEL=MiniMax-M2.7
# API_BASE=https://api.minimax.io/v1

CHATBI_DB_HOST=127.0.0.1
CHATBI_DB_PORT=3307
CHATBI_DB_NAME=chatbi_demo
CHATBI_DB_USER=demo_user
CHATBI_DB_PASSWORD=demo_pass

# Agent: ReAct multi-step loop (1=on). Legacy single-shot plan + one Skill when 0/false.
CHATBI_AGENT_REACT=1
# Max LLM rounds per user message (each round may execute one Skill).
CHATBI_AGENT_MAX_STEPS=8

FRONTEND_API_BASE_URL=http://localhost:8000

# JWT for authenticated API（生产环境务必设置强随机密钥）
CHATBI_JWT_SECRET=change-me-in-production
CHATBI_JWT_EXP_HOURS=168

# 用户登录（默认 1=开启）。docker-compose.dev.yml 中为 false；生产务必保持开启或省略本项
# CHATBI_AUTH_ENABLED=1
# 免登录模式下会话归属的数据库用户 id（默认种子管理员 id=1）
# CHATBI_AUTH_DEV_USER_ID=1

# 设为 1/true 时跳过记忆写入与 prompt 注入（仍保留用户与会话隔离）
# CHATBI_MEMORY_DISABLED=0
